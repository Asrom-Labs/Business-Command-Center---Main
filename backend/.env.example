# ── Required ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@host:5432/bcc_db

# JWT signing secret — must be at least 64 random characters in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_random_64_character_string_in_production_minimum

# ── Optional (defaults shown) ─────────────────────────────────────────────────
# Server port
PORT=3001

# Environment: development | production | test
NODE_ENV=development

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
